rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // 2. Loans Collection
    match /loans/{loanId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.borrowerId == request.auth.uid;
      allow update: if isSignedIn() && (
        (resource.data.borrowerId == request.auth.uid && request.resource.data.borrowerId == request.auth.uid) || 
        (request.resource.data.amount < resource.data.amount && 
         request.resource.data.amount >= 0 &&
         request.resource.data.borrowerId == resource.data.borrowerId)
      );
      allow delete: if isSignedIn() && resource.data.borrowerId == request.auth.uid;
    }

    // 3. Investments Collection
    match /investments/{investmentId} {
      allow read: if isSignedIn() && resource.data.investorId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.investorId == request.auth.uid;
    }
  }
}

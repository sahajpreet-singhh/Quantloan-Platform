rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read, write: if isSignedIn() && (userId == request.auth.uid);
    }

    // 2. Loans Collection
    match /loans/{loanId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().borrowerId == request.auth.uid;
      allow update: if isSignedIn() && existing().borrowerId == request.auth.uid;
    }

    // 3. Investments Collection
    match /investments/{investmentId} {
      allow read: if isSignedIn() && (resource == null || resource.data.investorId == request.auth.uid);
      allow create: if isSignedIn() && incoming().investorId == request.auth.uid;
    }
  }
}
